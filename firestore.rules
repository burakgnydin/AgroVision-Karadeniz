rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) 
        && incoming().displayName is string 
        && incoming().displayName.size() <= 50;
      allow update: if isOwner(userId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'location', 'cropType', 'role']);
    }

    // --- Forum Posts ---
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && incoming().authorId == request.auth.uid
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().content is string && incoming().content.size() <= 5000
        && incoming().likesCount == 0;
      allow update: if isSignedIn() && (
        // Action: Edit Post (Author Only)
        (existing().authorId == request.auth.uid && incoming().authorId == existing().authorId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'crop', 'imageUrl', 'likesCount'])) ||
        // Action: Like (Anyone)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && 
         incoming().likesCount == existing().likesCount + 1)
      );
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;

      // --- Comments ---
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() 
          && incoming().authorId == request.auth.uid
          && incoming().postId == postId;
        allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
      }
    }

    // --- Analyses ---
    match /analyses/{analysisId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
